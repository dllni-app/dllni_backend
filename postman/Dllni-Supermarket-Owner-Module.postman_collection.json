                        },
                        "description": "Bulk create store products from active master products.\n\nRequest props:\n- storeId: integer (required)\n- products: array (required, min 1)\n- products[].categoryId: integer (required)\n- products[].masterProductId: integer (required)\n- products[].title: string (required)\n- products[].price: number (required)\n- products[].stockQuantity: integer (required)\n- products[].lowStockThreshold: integer (optional)\n- products[].discountedPrice: number (optional, <= price)\n- products[].description: string (optional)\n- products[].expiresAt: date/datetime (optional)\n- products[].isAvailable: boolean (optional)"
                    },
