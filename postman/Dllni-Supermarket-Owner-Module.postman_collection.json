                            "raw": "{\n  \"storeId\": {{storeId}},\n  \"products\": [\n    {\n      \"categoryId\": 4,\n      \"masterProductId\": 11,\n      \"title\": \"Sesame Oil Premium\",\n      \"price\": 3.75,\n      \"stockQuantity\": 25,\n      \"lowStockThreshold\": 5,\n      \"discountedPrice\": 3.25,\n      \"description\": \"Optional override description\",\n      \"expiresAt\": \"2026-12-31\",\n      \"isAvailable\": true\n    },\n    {\n      \"categoryId\": 4,\n      \"masterProductId\": 12,\n      \"title\": \"Olive Oil 1L\",\n      \"price\": 6.5,\n      \"stockQuantity\": 14\n    }\n  ]\n}"
