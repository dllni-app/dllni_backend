                        "description": "Owner KPI endpoint for cards/charts.\n\nQuery props:\n- range: today|week|month|year|custom\n- from: YYYY-MM-DD (required when range=custom)\n- to: YYYY-MM-DD (required when range=custom)."
                    },
                    "response": [
                        {
                            "name": "200 OK - performance",
                            "status": "OK",
                            "code": 200,
                            "_postman_previewlanguage": "json",
                            "header": [],
                            "cookie": [],
                            "body": "{\n  \"range\": {\n    \"key\": \"today\",\n    \"from\": \"2026-04-07\",\n    \"to\": \"2026-04-07\"\n  },\n  \"summary\": {\n    \"totalOrders\": 34,\n    \"newOrdersCount\": 7,\n    \"confirmedOrdersCount\": 10,\n    \"completedOrdersCount\": 14,\n    \"totalRevenue\": 2480.5,\n    \"averageOrderValue\": 72.96,\n    \"cancellationRatePercent\": 5.9\n  },\n  \"topProducts\": [\n    {\n      \"productId\": 10,\n      \"name\": \"Burger Combo\",\n      \"quantity\": 22,\n      \"revenue\": 770\n    }\n  ],\n  \"fulfillment\": {\n    \"averagePrepTimeMinutes\": 18,\n    \"averageReadyToPickupMinutes\": 26,\n    \"delayedOrdersPercent\": 12,\n    \"onTimePercent\": 88\n  },\n  \"offersImpact\": {\n    \"discountedOrdersCount\": 8,\n    \"conversionRatePercent\": 13,\n    \"discountedRevenue\": 640,\n    \"totalSavings\": 90\n  }\n}"
                        }
                    ]
                }
            ]
