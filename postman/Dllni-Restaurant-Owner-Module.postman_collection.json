                            "_postman_previewlanguage": "json",
                            "header": [],
                            "cookie": [],
                            "body": "{\n  \"data\": {\n    \"id\": 120,\n    \"status\": \"accepted\",\n    \"items\": [\n      {\n        \"id\": 7,\n        \"productId\": 15,\n        \"name\": \"Chicken Wrap\",\n        \"quantity\": 1,\n        \"unitPrice\": 6,\n        \"totalPrice\": 6\n      }\n    ],\n    \"paymentBreakdown\": {\n      \"subtotal\": 21,\n      \"deliveryFee\": 2,\n      \"serviceFee\": 1,\n      \"discount\": 0,\n      \"total\": 24\n    }\n  }\n}"
