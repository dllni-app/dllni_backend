              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [],
              "cookie": [],
              "body": "{\n  \"data\": [\n    {\n      \"id\": 1,\n      \"bookingNumber\": \"CLN-0001\",\n      \"status\": \"pending\",\n      \"scheduledDate\": \"2026-04-07\",\n      \"scheduledTime\": \"10:00\",\n      \"locationName\": \"Home\",\n      \"numberOfRooms\": 3,\n      \"estimatedHours\": 2,\n      \"totalPrice\": 50,\n      \"customer\": {\n        \"id\": 88,\n        \"name\": \"Mariam\",\n        \"phone\": \"+963944009999\"\n      }\n    }\n  ],\n  \"links\": {\n    \"first\": \"http://Dllni.test/api/v1/cleaning-bookings?page=1\",\n    \"last\": \"http://Dllni.test/api/v1/cleaning-bookings?page=1\",\n    \"prev\": null,\n    \"next\": null\n  },\n  \"meta\": {\n    \"current_page\": 1,\n    \"per_page\": 20,\n    \"total\": 1\n  }\n}"
