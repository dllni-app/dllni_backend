{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "nunomaduro/laravel-starter-kit",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.4.0",
        "dedoc/scramble": "^0.13.14",
        "devkandil/notifire": "^1.2.4",
        "filament/filament": "5.2.1",
        "google-gemini-php/laravel": "^2.0.3",
        "laravel/framework": "^12.53.0",
        "laravel/sanctum": "^4.3.1",
        "mustafafares/laravel-auto-crud": "^5.0.1",
        "nunomaduro/essentials": "^1.1.0",
        "nwidart/laravel-modules": "^12.0.4",
        "pusher/pusher-php-server": "^7.2.7",
        "rap2hpoutre/fast-excel": "^5.6",
        "spatie/laravel-data": "^4.19.1",
        "spatie/laravel-medialibrary": "^11.20.0",
        "spatie/laravel-permission": "^7.2",
        "spatie/laravel-query-builder": "^6.4.2",
        "typesense/typesense-php": "^5.2"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.1.9",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.9.2",
        "laravel/boost": "^2.1.8",
        "laravel/pail": "^1.2.6",
        "laravel/pint": "^1.27.1",
        "laravel/telescope": "^5.17.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.1",
        "pestphp/pest": ">=4.4.1",
        "pestphp/pest-plugin-laravel": "^4.0.0",
        "pestphp/pest-plugin-type-coverage": "^4.0.3",
        "rector/rector": "^2.3.7",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Mrmarchone\\LaravelAutoCrud\\": "AutoCrud/",
            "Modules\\Cleaning\\Database\\Seeders\\": "Modules/Cleaning/database/seeders/",
            "Modules\\Resturants\\Database\\Seeders\\": "Modules/Resturants/database/seeders/",
            "Modules\\Resturants\\": "Modules/Resturants/app/",
            "Modules\\Cleaning\\": "Modules/Cleaning/app/",
            "Modules\\Supermarket\\": "Modules/Supermarket/app/",
            "Modules\\Supermarket\\Database\\Seeders\\": "Modules/Supermarket/database/seeders/",
            "Modules\\User\\": "Modules/User/app/",
            "Modules\\User\\Database\\Seeders\\": "Modules/User/database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan clear",
            "@update:requirements"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "update:requirements": [
            "composer bump",
            "npx npm-check-updates -u"
        ],
        "lint": [
            "rector",
            "pint --parallel",
            "npm run lint"
        ],
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run",
            "npm run test:lint"
        ],
        "test:unit": "pest --parallel --coverage --exactly=100.0",
        "test:types": "phpstan",
        "test": [
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
